# ReadEcho Pro 环境变量配置模板
# 将此文件复制为 .env 并修改相应配置

# --- 路径配置 ---
# FFMPEG路径 (Windows示例: C:\ffmpeg\bin, Linux/macOS: /usr/local/bin/ffmpeg)
FFMPEG_PATH=E:\\ffmpeg-8.1-essentials_build\\ffmpeg-8.1-essentials_build\\bin

# 数据库文件路径 (相对路径或绝对路径)
DATABASE_FILE=readecho_v1.db

# 日志目录 (相对于用户主目录)
LOG_DIR=.readecho/logs

# 临时音频文件路径
TEMP_AUDIO_FILE=temp_note.wav

# --- 音频配置 ---
# 音频采样率 (Hz)
SAMPLE_RATE=44100

# 录音时长 (秒)
RECORDING_DURATION=30

# --- AI配置 ---
# Whisper模型大小 (tiny, base, small, medium, large)
WHISPER_MODEL=tiny

# Ollama模型名称
OLLAMA_MODEL=qwen2.5:7b

# --- 在线搜索配置 ---
# 豆瓣API密钥（可选，用于中文书籍搜索）
DOUBAN_API_KEY=

# Google Books API密钥（可选，用于英文书籍搜索）
GOOGLE_BOOKS_API_KEY=

# 启用搜索缓存（true/false）
SEARCH_CACHE_ENABLED=true

# 缓存过期时间（秒），默认7天
SEARCH_CACHE_TTL=604800

# 搜索超时时间（秒）
SEARCH_TIMEOUT=10

# --- 窗口配置 ---
# 窗口标题
WINDOW_TITLE=ReadEcho Pro - GPU Accelerated

# 窗口尺寸
WINDOW_WIDTH=900
WINDOW_HEIGHT=700

# 窗口位置
WINDOW_X=300
WINDOW_Y=300

# --- 日志配置 ---
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志文件最大大小 (字节)
LOG_MAX_BYTES=5242880  # 5MB

# 日志备份数量
LOG_BACKUP_COUNT=5

# --- 主题配置 ---
# 默认主题 (dark 或 light)
DEFAULT_THEME=dark

# --- 高级配置 ---
# 启用调试模式 (true/false)
DEBUG=false

# 启用模型预加载 (true/false)
PRELOAD_MODELS=true

# 预加载延迟 (毫秒)
PRELOAD_DELAY=500